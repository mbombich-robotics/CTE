# Node.js dependencies (do not commit these!)
node_modules/

# Environment variables (contains API keys - NEVER commit!)
.env

# Package lock files (optional - some prefer to commit these)
package-lock.json

# OS-specific files
.DS_Store
Thumbs.db

# IDE/Editor files
.vscode/
.idea/
*.swp
*.swo

# Log files
*.log
npm-debug.log*

# Temporary files
*.tmp
*.temp

# Quiz question content — kept private so students can't see questions on GitHub
# Paste quiz-content.js as a second file in the Apps Script project
**/quiz-content.js

# Printable exam copies with answer keys — for emailing to admin only
Unit_05_Programming_Electronics_and_Sensors/Final_Exam_Print/

# Raw personal travel documents (booking confirmations, tickets, etc.) —
# these contain PINs, card digits, unique QR/barcodes, or other sensitive
# data. Only the redacted + password-protected copies in Travel/documents/
# are meant to be committed. Drop raw uploads directly in Travel/, not
# in a subfolder, so this catches them.
Travel/*.pdf

